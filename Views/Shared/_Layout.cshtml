<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CV Builder</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>

    <!-- ===== TOP NAVIGATION BAR ===== -->
    <nav class="navbar navbar-dark fixed-top shadow-sm" style="background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);">
        <div class="container-fluid">
            <!-- Sidebar Toggle Button -->
            <button class="btn btn-outline-light" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu">
                <i class="fas fa-bars"></i>
            </button>
            <!-- Brand / Platform Name -->
            <a class="navbar-brand mx-auto fw-bold" href="/" style="letter-spacing: 1px; font-size: 1.4rem;">
                <i class="fas fa-file-alt me-2"></i>CV Builder
            </a>
            <!-- Empty div to keep flex spacing balanced -->
            <div style="width:40px;"></div>
        </div>
    </nav>

    <!-- ===== SIDEBAR (Offcanvas - Collapsed by default) ===== -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarMenu" aria-labelledby="sidebarMenuLabel" style="background: #1e2a3a; color: white; width: 280px;">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title fw-bold" id="sidebarMenuLabel">
                <i class="fas fa-compass me-2"></i>Navigation
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0">
            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a class="nav-link text-white py-3 px-4" href="/">
                        <i class="fas fa-home me-3" style="width:20px;"></i> Home / CV View
                    </a>
                </li>
                <li class="nav-item border-top border-secondary">
                    <a class="nav-link text-white py-3 px-4" href="/Admin/Login">
                        <i class="fas fa-sign-in-alt me-3" style="width:20px;"></i> Admin Login
                    </a>
                </li>
                <li class="nav-item border-top border-secondary">
                    <a class="nav-link text-white py-3 px-4" href="/Admin/Dashboard">
                        <i class="fas fa-tachometer-alt me-3" style="width:20px;"></i> Admin Dashboard
                    </a>
                </li>
                <li class="nav-item border-top border-secondary">
                    <a class="nav-link text-white-50 py-3 px-4" href="/Admin/Logout">
                        <i class="fas fa-sign-out-alt me-3" style="width:20px;"></i> Logout
                    </a>
                </li>
            </ul>
            <div class="position-absolute bottom-0 w-100 p-3 border-top border-secondary">
                <small class="text-white-50"><i class="fas fa-code me-1"></i> .NET Core 8</small>
            </div>
        </div>
    </div>

    <!-- ===== MAIN CONTENT AREA ===== -->
    <div class="container-fluid p-0" style="margin-top: 70px;">
        <!-- Top margin to prevent overlap with fixed navbar -->
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ===== FOOTER (Optional but clean) ===== -->
    <footer class="border-top footer text-muted text-center py-2 bg-light" style="position: fixed; bottom: 0; width: 100%; font-size: 0.85rem;">
        <div class="container">
            &copy; 2026 - CV Builder - <a href="/Home/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>