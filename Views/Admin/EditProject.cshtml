@model CV_Builder.Models.Project
@{
    ViewData["Title"] = Model.Id == 0 ? "Add Project" : "Edit Project";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width:600px;">
    <h2>@(Model.Id == 0 ? "Add New" : "Edit") Project</h2>

    <form method="post">
        <div class="form-group">
            <label>Project Name</label>
            <input asp-for="Title" class="form-control" />
        </div>

        <div class="form-group mt-2">
            <label>Short Description</label>
            <textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-group mt-2">
            <label>Technologies & Tools</label>
            <input asp-for="Technologies" class="form-control" />
        </div>

        <div class="form-group mt-2">
            <label>GitHub Link</label>
            <input asp-for="GithubLink" class="form-control" placeholder="github.com/yourusername" />
        </div>

        <div class="form-group mt-2">
            <label>Display Order</label>
            <input asp-for="DisplayOrder" class="form-control" type="number" value="1" />
        </div>

        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-primary mt-3">Save Project</button>
        <a asp-action="Dashboard" class="btn btn-secondary mt-3">Cancel</a>
    </form>
</div>